{
  "name": "@unraid/js-standards",
  "version": "1.5.0",
  "description": "Lime Technology shared JS/TS code-quality presets: ESLint (type-aware, strict), Oxlint, Prettier, tsconfig, and knip.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unraid/js-standards"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src"
  ],
  "exports": {
    "./eslint/base": "./src/eslint/base.js",
    "./eslint/nuxt": "./src/eslint/nuxt.js",
    "./eslint/worker": "./src/eslint/worker.js",
    "./eslint/node": "./src/eslint/node.js",
    "./eslint/typescript": "./src/eslint/typescript.js",
    "./eslint/quality": "./src/eslint/quality.js",
    "./eslint/strict-size": "./src/eslint/strict-size.js",
    "./eslint/vue": "./src/eslint/vue.js",
    "./eslint/react": "./src/eslint/react.js",
    "./eslint/cloudflare-workers": "./src/eslint/cloudflare-workers.js",
    "./eslint/testing": "./src/eslint/testing.js",
    "./eslint/oxlint": "./src/eslint/oxlint.js",
    "./eslint/ignores": "./src/eslint/ignores.js",
    "./eslint/globals": "./src/eslint/globals.js",
    "./prettier": "./src/prettier/index.json",
    "./tsconfig/base.json": "./src/tsconfig/base.json",
    "./tsconfig/nuxt.json": "./src/tsconfig/nuxt.json",
    "./tsconfig/worker.json": "./src/tsconfig/worker.json",
    "./tsconfig/node.json": "./src/tsconfig/node.json",
    "./knip/base": "./src/knip/base.js",
    "./oxlint/base": "./src/oxlint/base.json",
    "./oxlint/type-aware": "./src/oxlint/type-aware.json",
    "./stylelint/base": "./src/stylelint/base.js",
    "./stylelint/design-tokens": "./src/stylelint/design-tokens.js"
  },
  "scripts": {
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "eslint . && node --test \"test/**/*.test.mjs\"",
    "test:rules": "node --test \"test/**/*.test.mjs\""
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint-react/eslint-plugin": "^5.18.0",
    "@eslint/js": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-deslop": "^0.3.6",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-oxlint": "^1.72.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-unicorn": "^69.0.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "stylelint-config-standard": "^40.0.0",
    "typescript-eslint": "^8.62.1"
  },
  "peerDependencies": {
    "@nuxt/eslint-config": ">=1.16.0",
    "eslint": ">=10.4.0",
    "stylelint": ">=16.0.0",
    "typescript": ">=5.5.0"
  },
  "peerDependenciesMeta": {
    "@nuxt/eslint-config": {
      "optional": true
    },
    "stylelint": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^1.16.0",
    "eslint": "^10.6.0",
    "stylelint": "^17.14.0",
    "typescript": "^5.9.3",
    "vue-eslint-parser": "^10.4.1"
  },
  "packageManager": "pnpm@10.33.0"
}
